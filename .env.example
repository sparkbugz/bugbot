# =============================================================================
# BugBot configuration
#
# HOW CONFIGURATION WORKS
#   This file (or the process environment) is read every time the bot starts.
#   It provides two kinds of values:
#
#     1. Secrets and infrastructure — ALWAYS read from the environment and never
#        stored in the database: DISCORD_TOKEN, DISCORD_OAUTH_CLIENT_ID/SECRET,
#        ADMIN_SESSION_SECRET, GITHUB_TOKEN, DATABASE_PATH, the ADMIN_WEB_*
#        settings, BOT_MODULES, and the DISCORD_ADMIN_* administrator lists.
#
#     2. First-run defaults for the feature settings below (channels, matching,
#        moderation, welcome, leveling, and the rest).
#
#   Once the bot has run and you save changes in the admin panel, those feature
#   settings live in the SQLite database (DATABASE_PATH, default ./data/bot.db)
#   and TAKE PRECEDENCE. On every startup the stored values are overlaid on top
#   of this file, so editing a panel-managed setting HERE after the first run
#   has NO effect — change it on the Settings page instead. The secrets and
#   infrastructure keys in group (1) are the exception: they are only ever read
#   from the environment.
#
#   FAQ entries, moderation rules, custom commands, and access grants also live
#   in SQLite. FAQ entries and moderation rules seed once from FAQ_DATA_PATH /
#   MODERATION_RULES_PATH on the very first run, then the database owns them.
#
# SECRETS
#   Do not put real tokens in this file. In production, provide secrets through
#   your host or process-manager secret store. `npm run setup` can write a
#   chmod 600 .env for local use. GITHUB_TOKEN is only needed for private repos
#   or higher GitHub API limits.
#
#   Required secret, supply via your secret store (not committed here):
#     DISCORD_TOKEN=your-discord-bot-token
# =============================================================================
DISCORD_CLIENT_ID=
BOT_NAME=BugBot
FAQ_DATA_PATH=./data/faq.json
DATABASE_PATH=./data/bot.db
BOT_MODULES=faq,github
DISCORD_ALLOWED_CHANNEL_IDS=123456789012345678
DISCORD_IGNORED_CHANNEL_IDS=
DISCORD_CONTROL_GUILD_ID=
# Administrators: the server owner and anyone matching the values below always
# have FULL access to the panel and every command, and cannot be locked out.
# Scoped access for other roles/users is granted at runtime — from the panel's
# Access page, the `<prefix> access` Discord command, or `npm run access`.
DISCORD_ADMIN_USER_IDS=
DISCORD_ADMIN_ROLE_IDS=
DISCORD_ADMIN_PERMISSION_FLAGS=Administrator,ManageGuild,ManageMessages,ModerateMembers
MANAGEMENT_COMMAND_PREFIX=!faqbot
# Register /commands (/faq, /rank, /ban, …) in the control server. The command
# set follows the enabled features; requires a control guild ID.
ENABLE_SLASH_COMMANDS=true
# Answer exact triggers (e.g. !rules) with a fixed response, managed on the
# Commands page. Separate from the fuzzy FAQ matcher.
ENABLE_CUSTOM_COMMANDS=false
# Community commands: /poll for reaction polls, /giveaway for timed draws.
ENABLE_POLLS=false
ENABLE_GIVEAWAYS=false
QUESTION_ONLY_MODE=true
MATCH_THRESHOLD=0.72
RESPONSE_COOLDOWN_SECONDS=60
USER_MESSAGE_COOLDOWN_SECONDS=5
MAX_MESSAGE_LENGTH=1000
MAX_REPLY_LENGTH=1900
GITHUB_DEFAULT_REPOS=owner/repo
ENABLE_GLOBAL_GITHUB_SEARCH=false
GLOBAL_GITHUB_SEARCH_MIN_SCORE=0.63
GITHUB_CACHE_TTL_SECONDS=600
GITHUB_QUERY_MAX_LENGTH=256
GITHUB_REQUEST_TIMEOUT_SECONDS=8
MODERATION_RULES_PATH=./data/moderation.json
MODERATION_CHANNEL_IDS=
MODERATION_LOG_CHANNEL_ID=
MODERATION_EXEMPT_USER_IDS=
MODERATION_EXEMPT_ROLE_IDS=
MODERATION_DEFAULT_ACTION=timeout
MODERATION_DEFAULT_TIMEOUT_SECONDS=3600
MODERATION_BAN_DELETE_MESSAGE_SECONDS=86400
MODERATION_MAX_SCAN_LENGTH=4000
MODERATION_DRY_RUN=true
WELCOME_ENABLED=false
WELCOME_CHANNEL_ID=
WELCOME_MESSAGE=Welcome to {server}, {mention}! You are member #{count}.
GOODBYE_ENABLED=false
GOODBYE_CHANNEL_ID=
GOODBYE_MESSAGE={user} has left the server.
AUTO_ROLE_IDS=
REACTION_ROLES_ENABLED=false
# Starboard: repost a message to a highlights channel once it collects enough
# of the starboard emoji.
STARBOARD_ENABLED=false
STARBOARD_CHANNEL_ID=
STARBOARD_EMOJI=⭐
STARBOARD_THRESHOLD=3
LEVELING_ENABLED=false
XP_PER_MESSAGE=15
XP_COOLDOWN_SECONDS=60
LEVEL_UP_ENABLED=true
LEVEL_UP_CHANNEL_ID=
LEVEL_UP_MESSAGE=GG {mention}, you reached level {level}!
LEVEL_ROLES=
LOGGING_ENABLED=false
LOG_CHANNEL_ID=
LOG_MESSAGE_DELETES=true
LOG_MESSAGE_EDITS=true
LOG_JOINS_LEAVES=true
ADMIN_WEB_PROTOCOL=http
ADMIN_WEB_HOST=127.0.0.1
ADMIN_WEB_PORT=8787
ADMIN_WEB_PUBLIC_URL=http://127.0.0.1:8787
ADMIN_WEB_TLS_CERT_PATH=
ADMIN_WEB_TLS_KEY_PATH=
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/oauth/callback
ADMIN_SESSION_SECRET=
# Enables the dangerous process-exit restart button. Leave false unless a
# supervisor such as systemd, Docker, or PM2 will immediately start the bot again.
ALLOW_PROCESS_RESTART=false

# --- Docker Compose only (ignored when running Node directly) ---
# Which published image tag docker-compose.yml pulls from GHCR. Defaults to
# :latest (auto-updated by the watchtower service). Pin a release to opt out of
# auto-update, e.g. BUGBOT_TAG=v0.1.0
BUGBOT_TAG=latest
